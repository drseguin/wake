# WAKE App Environment Variables
#
# Usage:
#   cp .env.example .env                    # default for ./start.sh
#   cp .env.example .env.local              # loaded by ./start.sh --env local
#   cp .env.example .env.prod               # loaded by ./start.sh --env prod
#
# ./start.sh --env <name> sources .env.<name>, then uses APP_HOST to
# regenerate nginx/nginx.conf from nginx.conf.template each run.

# Application name. Displayed in the UI, logs, and shell scripts.
APP_NAME=WAKE App

# Public hostname nginx serves on. Used for the self-signed SSL cert subject
# and substituted into nginx.conf. Keep as 'localhost' for local dev.
APP_HOST=localhost

# Host port the app is served on (HTTPS). Defaults to 443. Change this if 443
# is taken, e.g. APP_PORT=8444. The Keycloak admin port stays on 8443.
APP_PORT=443

# Flask secret key for session signing. ROTATE in any shared environment.
FLASK_SECRET_KEY=2af2fffdedc459525f27c52fddf42fe7aeba729afd09d49ff13597650e80b86a

# Redis connection URL (set automatically by docker-compose).
REDIS_URL=redis://redis:6379/0

# WAKE app database (PostgreSQL + PostGIS) password. The DATABASE_URL is
# assembled in docker-compose.yml using this value. CHANGE in any shared
# environment.
WAKE_DB_PASSWORD=wake

# Backend log level. NONE / ERROR / WARN / INFO / DEBUG.
# Applies to both the Python logger and the frontend logger via /api/v1/config.
LOG_LEVEL=DEBUG

# Note: Single user mode is controlled in backend/keycloak.json
# Set "single_user_mode": true to bypass Keycloak for local development.
# Set "single_user_mode": false to enable Keycloak SSO authentication.
#
# Note: For any APP_HOST other than localhost, also update the Keycloak URLs
# in backend/keycloak.json (public_url, app_url) and keycloak/realm-export.json
# (redirectUris, webOrigins) to match. This is left manual by design — those
# values are tied to your Keycloak realm configuration.
