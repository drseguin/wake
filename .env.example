# Base App Environment Variables
# Copy this file to .env and adjust values for your environment.

# Set to 'true' for local development without Keycloak.
# Set to 'false' to enable Keycloak SSO authentication.
SINGLE_USER_MODE=true

# Flask secret key for session signing. Change this in production.
FLASK_SECRET_KEY=dev-secret-key-change-in-production

# Redis connection URL (set automatically by docker-compose).
REDIS_URL=redis://redis:6379/0
